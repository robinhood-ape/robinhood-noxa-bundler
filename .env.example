# Dev / deployer wallet (launches the token)
PRIVATE_KEY=0xyour_deployer_private_key_here

# Optional: comma-separated extra buyer keys. If empty, bot generates BUNDLE_WALLET_COUNT keys.
BUNDLE_PRIVATE_KEYS=

# How many wallets to generate when BUNDLE_PRIVATE_KEYS is empty
BUNDLE_WALLET_COUNT=5

# RPC
RPC_URL=https://rpc.mainnet.chain.robinhood.com

# Safety
DRY_RUN=true

# Token metadata
TOKEN_NAME=My Token
TOKEN_SYMBOL=MTK
TOKEN_DESCRIPTION=Launched via NOXA bundler
# ipfs://... or https://... (can be empty)
METADATA_URI=
TWITTER=
TELEGRAM=
WEBSITE=
DISCORD=
FARCASTER=

# Launch: creator buy baked into launch tx (msg.value = this + 0.0005 ETH fee)
INITIAL_BUY_ETH=0.05

# Per bundle-wallet buy size (after launch)
BUY_AMOUNT_ETH=0.01

# dexId 0 = Uniswap V3 on Robinhood; launchConfigId usually 0
DEX_ID=0
LAUNCH_CONFIG_ID=0

# Slippage for bundle buys (bps)
SLIPPAGE_BPS=1000

# Extra ETH left on each wallet for gas when funding
GAS_RESERVE_ETH=0.002
 